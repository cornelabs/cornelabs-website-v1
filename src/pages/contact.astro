---
import Contactform from "@components/contactform.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact</Fragment>
      <Fragment slot="desc">Let's create something amazing together.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">Contact Corne Labs</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          Have a project in mind or questions about our services? Reach out to
          us and let's start the conversation.
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:map-marker" />
            <span>Lagos, Nigeria</span>
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
              href="mailto:hello@cornelabs.com">hello@cornelabs.com</a
            >
            <!-- </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
              href="tel:+234 (817) 938 6053">+234 (817) 938 6053</a
            > -->
          </div>
          <div class="mt-8">
            <h3 class="text-lg font-medium text-gray-800">Connect with us</h3>
            <div class="flex space-x-4 mt-3">
              <a
                href="https://linkedin.com/company/cornelabs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-blue-700">
                <Icon class="w-6 h-6" name="simple-icons:linkedin" />
              </a>
              <a
                href="https://twitter.com/corne_labs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-blue-500">
                <Icon class="w-6 h-6" name="simple-icons:twitter" />
              </a>
              <a
                href="https://instagram.com/corne_labs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-pink-600">
                <Icon class="w-6 h-6" name="simple-icons:instagram" />
              </a>
              <a
                href="https://facebook.com/cornelabs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-blue-600">
                <Icon class="w-6 h-6" name="simple-icons:facebook" />
              </a>
              <a
                href="https://tiktok.com/cornelabs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-gray-400">
                <Icon class="w-6 h-6" name="simple-icons:tiktok" />
              </a>
              <a
                href="https://youtube.com/corne-labs"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 hover:text-red-600">
                <Icon class="w-6 h-6" name="simple-icons:youtube" />
              </a>
            </div>
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
