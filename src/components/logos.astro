---
// @ts-ignore
import { Icon } from "astro-icon/components";
---

<div class="mt-24">
  <h2 class="text-center text-slate-500">Wide range of technology expertise</h2>
  <div class="flex gap-8 md:gap-20 items-center justify-center mt-10 flex-wrap">

    <Icon class="size-8 md:size-12" name="devicon:react" />
    <Icon class="size-8 md:size-12" name="devicon:nodejs" />
    <Icon class="size-8 md:size-12" name="devicon:angular" />
    <Icon class="size-8 md:size-16" name="devicon:javascript" />
    <Icon class="size-8 md:size-16" name="devicon:java" />
    <Icon class="size-8 md:size-12" name="skill-icons:rails" />

  </div>
</div>
